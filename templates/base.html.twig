<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}YNot{% endblock %}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ asset('ynot.css') }}">
  {% block head %}{% endblock %}
</head>
<body>
<header>
  <div class="wrap nav">
    <div class="brand"><span>y</span>-not</div>
    <nav>
      <a href="{{ path('site_index') }}">Fonctionnalités</a>
      <a href="{{ path('site_index') }}#decouvrir">Activités</a>
      <a href="{{ path('site_team') }}">Notre équipe</a>
      <a class="btn btn-primary" href="{{ path('site_index') }}#cta">Télécharger l'app</a>
    </nav>
  </div>
</header>

<main>{% block body %}{% endblock %}</main>

<footer>
  <div class="wrap foot">
    <div class="brand"><span>y</span>-not</div>
    <small>© {{ "now"|date("Y") }} YNot. Tous droits réservés.</small>
  </div>
</footer>
</body>
</html>
