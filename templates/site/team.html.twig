    <script src="https://unpkg.com/animejs@3.2.1/lib/anime.min.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof anime === 'undefined') return;

        anime.timeline({
          easing: 'easeOutQuad',
          duration: 700
        })
          .add({
            targets: '.logo',
            scale: [0.6, 1],
            opacity: [0, 1],
            rotate: [-10, 0]
          })
          .add({
            targets: '.team-hero .kicker',
            translateY: [14, 0],
            opacity: [0, 1]
          }, '-=420')
          .add({
            targets: '.team-hero h1',
            translateY: [20, 0],
            opacity: [0, 1]
          }, '-=420')
          .add({
            targets: '.hero-sub',
            translateY: [10, 0],
            opacity: [0, 1]
          }, '-=450');

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (!entry.isIntersecting) return;

            anime({
              targets: entry.target.querySelectorAll('h2, .team-separator, .member-card'),
              opacity: [0, 1],
              translateY: [22, 0],
              duration: 550,
              delay: anime.stagger(90),
              easing: 'easeOutQuad'
            });

            obs.unobserve(entry.target);
          });
        }, { threshold: 0.18 });

        document.querySelectorAll('.team-category').forEach(el => observer.observe(el));
      });
    </script>
